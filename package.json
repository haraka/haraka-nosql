{
  "name": "haraka-nosql",
  "version": "0.5.0",
  "description": "Unified NoSQL API for RAM, SSC, or Redis",
  "author": {
    "name": "Matt Simerson",
    "url": "https://github.com/haraka/haraka-nosql"
  },
  "files": [
    "CHANGELOG.md"
  ],
  "main": "index.js",
  "homepage": "https://github.com/haraka/haraka-nosql",
  "keywords": [
    "email",
    "mail",
    "nosql",
    "redis",
    "strong store cluster"
  ],
  "bugs": {
    "url": "https://github.com/haraka/haraka-nosql/issues"
  },
  "config": {
    "blanket": {
      "pattern": "index.js"
    }
  },
  "scripts": {
    "test": "npx mocha --exit",
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint *.js test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "versions": "npx dependency-version-checker check",
    "versions:fix": "npx dependency-version-checker update && npm run prettier:fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/haraka/haraka-nosql.git"
  },
  "devDependencies": {
    "@haraka/eslint-config": "^2.0.2",
    "mocha": "^11.5.0"
  },
  "license": "MIT",
  "dependencies": {},
  "optionalDependencies": {
    "redis": "^5.1.1",
    "strong-store-cluster": "^1.0.1"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}
